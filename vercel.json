{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api(/.*)?", "dest": "/index.js" },
    { "src": "/generate", "dest": "/index.js" },
    { "src": "/presets", "dest": "/index.js" },
    { "src": "/session/(.*)", "dest": "/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
